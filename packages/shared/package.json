{
  "name": "@chat/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests'",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt \"src/**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "format:check": "oxfmt --check \"src/**/*.{ts,tsx,js,jsx,mjs,cjs}\""
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
