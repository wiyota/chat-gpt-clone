{
  "name": "chat-gpt-clone",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.14.0",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @chat/web test:e2e",
    "test:e2e:ui": "pnpm --filter @chat/web test:e2e:ui",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt \"**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "ci:check": "pnpm --filter @chat/shared build && pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "clean": "pnpm -r exec rm -rf dist .turbo",
    "scan:secrets": "gitleaks detect --source . --verbose --redact",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tailwindcss": "^1.3.5",
    "typescript": "^7.0.2"
  }
}
