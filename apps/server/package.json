{
  "name": "@chat/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt \"src/**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "format:check": "oxfmt --check \"src/**/*.{ts,tsx,js,jsx,mjs,cjs}\""
  },
  "dependencies": {
    "@chat/shared": "workspace:*",
    "@hono/node-server": "^2.0.8",
    "@hono/typebox-validator": "1.1.0",
    "@sinclair/typebox": "0.34.52",
    "@supabase/supabase-js": "2.110.2",
    "dotenv": "^17.4.2",
    "hono": "^4.12.29",
    "js-tiktoken": "^1.0.21",
    "openai": "^6.46.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
